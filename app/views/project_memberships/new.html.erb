<div class="container mx-auto p-6">
  <h1 class="text-2xl font-bold mb-4">Add Members to <%= @project.name %></h1>

  <%= form_with(url: project_project_memberships_path(@project), class: "space-y-4") do |f| %>
    <div class="field">
      <%= f.label :user_ids, "Select Users:", class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= collection_select :user, :user_ids, @available_users, :id, :email, {}, { class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline", multiple: true } %>
    </div>

    <div>
      <%= submit_tag 'Add Members', class: "bg-indigo-500 hover:bg-indigo-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline" %>
    </div>
  <% end %>

  <%= link_to 'Back to Project', project_path(@project), class: "inline-block mt-4 text-blue-500 hover:underline" %>
</div>
