<h2 class="text-xl font-bold mt-4 mb-2">Change Status</h2>
<%= form_with(model: @project, url: project_path(@project), method: :patch, class: "space-y-2") do |f| %>
  <div class="field">
    <%= f.label :status, class: "block text-gray-700 text-sm font-bold mb-2" %>
    <%= f.select :status, Project.statuses.keys.map { |key| [key.humanize, key] }, { prompt: "Select Status" }, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
  </div>
  <%= f.submit 'Update Status', class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline" %>
<% end %>
