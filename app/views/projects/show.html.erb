<div class="container mx-auto p-6">
  <div class="flex flex-col lg:flex-row gap-6">
    <div class="w-full lg:w-2/3 space-y-6">
      <%= render "projects/show/product_info" %>
      <%= render "projects/show/project_histories" %>
      <%= render 'comments/comment_form' %>
    </div>
    <div class="w-full lg:w-1/3 space-y-6">
      <div class="bg-white rounded-xl shadow p-4">
        <%= render "projects/show/change_status" %>
      </div>
      <div class="bg-white rounded-xl shadow p-4">
        <%= render "projects/show/add_project_member" %>
      </div>
      <div class="flex gap-4 mt-4">
        <div class="bg-white rounded-xl shadow p-4">
          <%= link_to 'Back to Projects', projects_path, class: "text-blue-500 hover:underline" %> |
          <%= link_to 'Edit Project', edit_project_path(@project), class: "text-blue-500 hover:underline" %>
        </div>
      </div>
    </div>
  </div>
</div>

