<h2 class="text-xl font-bold mb-2">Leave a Comment</h2>
<%= form_with(model: @new_comment, url: project_comments_path(@project), class: "space-y-2") do |f| %>
  <div class="field">
<%= f.label :body, 'Comment:', class: "block text-gray-700 text-sm font-bold mb-2" %>
    <%= f.text_area :body, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
</div>
  <div>
    <%= f.submit 'Add Comment', class: "bg-green-500 hover:bg-green-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline" %>
  </div>
<% end %>
